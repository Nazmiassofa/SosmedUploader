# Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# Meta / Facebook API
# ============================================================
FB_USER_ACCESS_TOKEN = ""
FB_APP_ID = ""
FB_APP_SECRET = ""

FACEBOOK_PAGE_ID = ""
PAGE_ACCESS_TOKEN = ""
INSTAGRAM_ID = ""

# Optional: override per-platform tokens (falls back to PAGE_ACCESS_TOKEN)
# INSTAGRAM_ACCESS_TOKEN = ""
# FACEBOOK_ACCESS_TOKEN = ""

# ============================================================
# Redis
# ============================================================
REDIS_HOST = "127.0.0.1"
REDIS_PORT = 6379
REDIS_PASSWORD = ""
REDIS_CHANNEL = "job_vacancy_channel"
REDIS_LIMIT = 25

# ============================================================
# Cloudflare R2 Storage
# ============================================================
R2_ACCOUNT_ID = ""
R2_ACCESS_KEY = ""
R2_SECRET_KEY = ""
R2_BASE_URL = "https://media.mailezz.com"
R2_BUCKET = "media-job"

# ============================================================
# Application
# ============================================================
ENVIRONMENT = "DEV"
LOG_LEVEL = "INFO"
